{
  "name": "feed-app-server",
  "version": "1.0.0",
  "description": "Feed app API with switchable MongoDB and SQL backends",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src scripts tests",
    "lint:fix": "eslint src scripts tests --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "postman:build": "node scripts/build-postman.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint:fix && npm run format && npm run test && npm run postman:build"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.1",
    "mongodb-memory-server": "^11.2.0",
    "openapi-to-postmanv2": "^6.1.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
